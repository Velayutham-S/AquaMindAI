# Base URL of the existing AquaMind AI FastAPI backend.
# The frontend calls ONLY `${VITE_API_BASE_URL}/api/chat`.
#
# - Leave EMPTY for local dev (relative `/api/chat` via the Vite proxy, no CORS)
#   or for same-origin production deployments.
# - Set to an absolute URL (e.g. https://api.example.com) for a cross-origin
#   backend. The backend must then allow the frontend origin via CORS.
VITE_API_BASE_URL=

# Dev-only: target the Vite dev server proxies `/api/*` to (see vite.config.ts).
VITE_DEV_PROXY_TARGET=http://localhost:8000

# Optional: request timeout in milliseconds for backend calls (default 60000).
VITE_API_TIMEOUT=60000
