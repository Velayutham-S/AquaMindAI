# AquaMind AI backend configuration.

# Server bind address / port.
HOST=0.0.0.0
PORT=8000

# Logging level: DEBUG | INFO | WARNING | ERROR.
LOG_LEVEL=INFO

# Comma-separated list of allowed frontend origins (CORS).
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Conversation session cookie name.
SESSION_COOKIE_NAME=aquamind_session

# Warm the AI pipeline at startup (true) or lazily on first request (false).
WARMUP_ON_STARTUP=true

# --- The AI pipeline reads its LLM secrets from the project-root .env.testing --- #
# (the confirmed production LLM configuration). The backend itself never reads or
# logs these. Required keys in .env.testing:
#   PLANNER_TESTING_API_KEY                  -> OpenCode Zen (DeepSeek Flash 4)
#   SQL_GENERATOR_TESTING_API_KEY            -> OpenCode Zen (DeepSeek Flash 4)
#   RECOMMENDATION_DECISION_TESTING_API_KEY  -> Groq (llama-3.3-70b-versatile)
#   RECOMMENDATION_GENERATOR_TESTING_API_KEY -> OpenCode Zen (DeepSeek Flash 4)
#   RESPONSE_GENERATOR_TESTING_API_KEY       -> OpenCode Zen (DeepSeek Flash 4)
#   REQUESTS_PER_MINUTE                      -> per-provider rate-limit cap
# Keep .env.testing OUT of version control (see .gitignore).
